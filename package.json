{
  "name": "actual-mcp-workspace",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.10",
      "uuid": "^14.0.0",
      "vite": "^7.3.2"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "lint": "pnpm -r run lint",
    "format": "pnpm -r run format",
    "format:check": "pnpm -r run format:check",
    "test": "pnpm -r run test",
    "type-check": "pnpm -r --if-present run type-check",
    "quality": "pnpm -r --if-present run quality",
    "dev:mcp-server": "pnpm --filter actual-mcp dev",
    "watch:mcp-server": "pnpm --filter actual-mcp watch",
    "start:mcp-server": "pnpm --filter actual-mcp start",
    "test:mcp-server": "pnpm --filter actual-mcp test",
    "docs:mcp-server": "pnpm --filter actual-mcp docs:generate",
    "public:check:mcp-server": "pnpm --filter actual-mcp public:check"
  }
}
