# Actual Budget Server Connection (Required)
ACTUAL_SERVER_URL=
ACTUAL_PASSWORD=
ACTUAL_BUDGET_SYNC_ID=

# Optional: Budget encryption password (if different from server password)
# ACTUAL_BUDGET_ENCRYPTION_PASSWORD=

# Optional: Auto-sync interval in minutes (0 = disabled)
# AUTO_SYNC_INTERVAL_MINUTES=5

# Optional: Enable additional tool categories (default: false)
# ENABLE_BUDGET_MANAGEMENT=false
# ENABLE_ADVANCED_ACCOUNT_OPS=false
# ENABLE_UTILITY_TOOLS=false
