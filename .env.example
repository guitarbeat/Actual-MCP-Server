ACTUAL_SERVER_URL=
ACTUAL_PASSWORD=

# Budget Configuration
# Required: The sync ID of your budget file (auto-loads on server startup)
# Find this in your Actual Budget server's budget list
ACTUAL_BUDGET_SYNC_ID=

# Optional: If your Actual server uses a different encryption budget password set it here
ACTUAL_BUDGET_ENCRYPTION_PASSWORD=

# Auto-sync Configuration
# Optional: Automatically sync budget with server at regular intervals (in minutes)
# Set to 0 or omit to disable auto-sync (default: 0 - disabled)
# AUTO_SYNC_INTERVAL_MINUTES=5

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
CACHE_MAX_ENTRIES=1000

# Performance Monitoring
PERFORMANCE_LOGGING_ENABLED=true
PERFORMANCE_LOG_THRESHOLD_MS=1000
PERFORMANCE_CACHE_STATS_INTERVAL_MS=300000

# Optional Tool Categories
# Enable additional tools beyond the core 20 tools (default: false for all)
# Budget file management tools (get-budgets, load-budget, download-budget, sync, etc.)
ENABLE_BUDGET_MANAGEMENT=false
# Advanced account operations (create-account, close-account, reopen-account, delete-account)
ENABLE_ADVANCED_ACCOUNT_OPS=false
# Utility tools (get-id-by-name, run-query, get-server-version)
ENABLE_UTILITY_TOOLS=false
