# Actual Budget Server Configuration
# The URL of your Actual Budget server (e.g., http://localhost:5006 or https://actual.yourdomain.com)
ACTUAL_SERVER_URL=

# The password to authenticate with the Actual Budget server
ACTUAL_PASSWORD=

# The Sync ID of the budget you want to connect to
ACTUAL_BUDGET_SYNC_ID=

# Directory for storing local cache and data (default: .actual-data)
ACTUAL_DATA_DIR=.actual-data

# MCP Server Security
# Bearer token required for clients to connect to this MCP server over HTTP
MCP_AUTH_TOKEN=

# Logging
# Log level for the application (debug, info, warn, error)
LOG_LEVEL=info

# Web Server Configuration
# Comma-separated list of allowed origins for CORS (e.g., http://localhost:3000,https://app.example.com)
CORS_ALLOWED_ORIGINS=

# Rate limiting
# Maximum number of requests allowed per window (default: 100)
RATE_LIMIT_MAX=100

# Session management
# Time-to-live for sessions in milliseconds (default: 3600000 - 1 hour)
SESSION_TTL_MS=3600000
