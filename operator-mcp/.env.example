# Repository root (absolute path recommended). Defaults to process.cwd().
OPERATOR_REPO_ROOT=/workspace

# Required when using --enable-bearer for HTTP mode
OPERATOR_BEARER_TOKEN=replace-with-a-long-random-token-at-least-32-chars

# Required for apply-pending, git-commit, git-push, and git-rollback
OPERATOR_APPROVAL_SECRET=replace-with-a-secret-only-humans-know

# Optional: restrict git writes to branches with this prefix (e.g. cursor/)
OPERATOR_ALLOWED_BRANCH_PREFIX=cursor/

# HTTP listener (with --sse)
PORT=3001
