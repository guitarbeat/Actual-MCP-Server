{
  "name": "chase-csv-cleaner",
  "version": "1.0.0",
  "description": "Transform Chase CSV exports for Actual Budget import",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "csv-import": "tsx src/process-chase-statement.ts",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "keywords": [
    "chase",
    "csv",
    "actual-budget",
    "finance",
    "banking"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.4.6",
    "date-fns": "^4.1.0",
    "openai": "^4.71.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/node": "^20.11.19",
    "tsx": "^4.7.1",
    "typescript": "~5.3.3",
    "vitest": "^3.2.4"
  }
}
