{
  "name": "actual-mcp",
  "version": "1.6.5",
  "description": "Actual Budget MCP server exposing API functionality",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "actual-mcp": "build/index.js"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "watch": "tsc --watch",
    "dev": "tsx src/index.ts",
    "start": "node build/index.js",
    "inspector": "pnpm run build && dotenv -e .env -- sh -c 'npx @modelcontextprotocol/inspector -e ACTUAL_SERVER_URL=$ACTUAL_SERVER_URL -e ACTUAL_PASSWORD=$ACTUAL_PASSWORD -e ACTUAL_BUDGET_SYNC_ID=$ACTUAL_BUDGET_SYNC_ID node build/index.js'",
    "inspector:custom": "pnpm run build && npx @modelcontextprotocol/inspector node build/index.js",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx,.js",
    "lint:fix": "eslint . --ext .ts,.tsx,.js --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "docs:generate": "tsx scripts/sync-tool-docs.ts --write",
    "docs:check": "tsx scripts/sync-tool-docs.ts --check",
    "public:check": "tsx scripts/public-repo-check.ts",
    "quality": "pnpm run lint && pnpm run format:check && pnpm run type-check",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build && pnpm run docs:check && pnpm run public:check"
  },
  "dependencies": {
    "@actual-app/api": "^26.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "lru-cache": "^11.2.5",
    "openai": "^6.18.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@types/express": "^5.0.2",
    "@types/node": "^22.19.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "dotenv-cli": "^10.0.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eventsource": "^4.0.0",
    "fast-check": "^4.3.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.6",
    "prettier": "^3.8.1",
    "tsx": "^4.19.4",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "mcp",
    "actual-budget",
    "budgeting",
    "ai",
    "model-context-protocol",
    "actual"
  ],
  "license": "MIT"
}
