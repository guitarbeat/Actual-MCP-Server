{
  "name": "actual-mcp",
  "version": "1.6.0",
  "description": "Actual Budget MCP server exposing API functionality",
  "private": true,
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "actual-mcp": "build/index.js"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "watch": "tsc --watch",
    "dev": "tsx src/index.ts",
    "start": "node build/index.js",
    "inspector": "npm run build && dotenv -e .env -- sh -c 'npx @modelcontextprotocol/inspector -e ACTUAL_SERVER_URL=$ACTUAL_SERVER_URL -e ACTUAL_PASSWORD=$ACTUAL_PASSWORD -e ACTUAL_BUDGET_SYNC_ID=$ACTUAL_BUDGET_SYNC_ID node build/index.js'",
    "inspector:custom": "npm run build && npx @modelcontextprotocol/inspector node build/index.js",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "type-check": "tsc --noEmit",
    "quality": "npm run lint && npm run type-check",
    "prepare": "husky || true",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@actual-app/api": "^25.12.0",
    "@modelcontextprotocol/sdk": "^1.24.3",
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "lodash-es": "^4.17.21",
    "lru-cache": "^10.4.3",
    "openai": "^6.8.1",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@changesets/cli": "^2.29.4",
    "@types/express": "^5.0.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.19.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "dotenv-cli": "^10.0.0",
    "eventsource": "^4.0.0",
    "fast-check": "^4.3.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.6",
    "tsx": "^4.19.4",
    "typescript": "^5.3.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/guitarbeat/actual-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guitarbeat/actual-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/guitarbeat/actual-mcp/issues"
  },
  "keywords": [
    "mcp",
    "actual-budget",
    "budgeting",
    "ai",
    "model-context-protocol",
    "actual"
  ],
  "author": "guitarbeat",
  "license": "MIT"
}
