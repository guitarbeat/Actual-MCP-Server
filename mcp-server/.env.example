
ACTUAL_SERVER_URL=https://actual.example.com

# Set exactly one of ACTUAL_PASSWORD or ACTUAL_SESSION_TOKEN for remote-server auth
ACTUAL_PASSWORD=replace-with-your-actual-password
# ACTUAL_SESSION_TOKEN=replace-with-your-actual-session-token
ACTUAL_BUDGET_SYNC_ID=replace-with-your-budget-sync-id

# Optional for encrypted budgets
ACTUAL_BUDGET_ENCRYPTION_PASSWORD=

# Optional for remote HTTP mode
BEARER_TOKEN=replace-with-a-long-random-token
PORT=3000

# Optional behavior flags
# Remote deployments should set a non-zero sync interval to keep cached reads fresh
ACTUAL_READ_FRESHNESS_MODE=cached
# How long (ms) read paths may skip a lightweight getAccounts health probe; bounded 3000-300000 (default 20000)
ACTUAL_CONNECTION_HEALTH_TTL_MS=20000
AUTO_SYNC_INTERVAL_MINUTES=5
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300

# Optional smoke-test harness settings
# ACTUAL_TOOL_TEST_SANDBOX_BUDGET_ID is only needed for the full write/destructive sandbox pass.
# Recommended persistent sandbox budget name: Sandbox
ACTUAL_TOOL_TEST_SANDBOX_BUDGET_ID=
ACTUAL_TOOL_TEST_PREFIX=__mcp_tool_test__

# Remote streamable MCP session TTL - omit/false-y to disable idle pruning (see README)
MCP_SESSION_TTL_MINUTES=

# When true (HTTP mode), emitted stderr lines prepend shortened request + MCP session ids per tool invocation
MCP_TOOL_CORRELATION_LOGS=false

# When true (HTTP /ready), stderr line on each change to ready|status|reason (one line per correlation id per transition)
MCP_READINESS_TRANSITION_LOGS=false

# Positive integer emits periodic `[MCP_DIAG]` connection + RSS logs; omit/disable with empty to stay quiet
MCP_CONNECTION_DIAGNOSTICS_INTERVAL_SEC=

# Periodic `[TOOL_USAGE_SUMMARY]` stderr line with per-tool invocation counts (seconds between summaries; omit to disable)
MCP_TOOL_USAGE_SUMMARY_INTERVAL_SEC=

# get-transactions pagination knobs (omit for defaults)
ACTUAL_GET_TRANSACTIONS_DEFAULT_LIMIT=200
ACTUAL_GET_TRANSACTIONS_MAX_LIMIT=5000

# CORS: comma-separated list of allowed browser origins.
# Supports wildcard host patterns e.g. http://localhost:* or https://*.example.com
# Alias: CORS_ALLOWED_ORIGINS maps to MCP_ALLOWED_ORIGINS (set either one)
MCP_ALLOWED_ORIGINS=
# CORS_ALLOWED_ORIGINS=

# Logging: log level for output (trace|debug|info|warn|error|fatal). Default: info
LOG_LEVEL=info

# Rate limiting: max requests per minute per authorization token on /mcp (default: 60)
# MCP_RATE_LIMIT_RPM=60
