ACTUAL_SERVER_URL=https://actual.example.com

# Set exactly one of ACTUAL_PASSWORD or ACTUAL_SESSION_TOKEN for remote-server auth
ACTUAL_PASSWORD=replace-with-your-actual-password
# ACTUAL_SESSION_TOKEN=replace-with-your-actual-session-token
ACTUAL_BUDGET_SYNC_ID=replace-with-your-budget-sync-id

# Optional for encrypted budgets
ACTUAL_BUDGET_ENCRYPTION_PASSWORD=

# Optional for remote HTTP mode
BEARER_TOKEN=replace-with-a-long-random-token
PORT=3000

# Optional behavior flags
# Remote deployments should set a non-zero sync interval to keep cached reads fresh
ACTUAL_READ_FRESHNESS_MODE=cached
# How long (ms) read paths may skip a lightweight getAccounts health probe; bounded 3000–300000 (default 20000)
ACTUAL_CONNECTION_HEALTH_TTL_MS=20000
AUTO_SYNC_INTERVAL_MINUTES=5
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300

# Optional smoke-test harness settings
# ACTUAL_TOOL_TEST_SANDBOX_BUDGET_ID is only needed for the full write/destructive sandbox pass.
# Recommended persistent sandbox budget name: Sandbox
ACTUAL_TOOL_TEST_SANDBOX_BUDGET_ID=
ACTUAL_TOOL_TEST_PREFIX=__mcp_tool_test__
